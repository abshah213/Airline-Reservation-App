<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Aadhar_number_Validation</fullName>
    <active>false</active>
    <errorConditionFormula>OR(ISBLANK( Aadhar_Number__c ) ,  
   LEN( TEXT(Aadhar_Number__c)) &lt; 12 
   )</errorConditionFormula>
    <errorDisplayField>Aadhar_Number__c</errorDisplayField>
    <errorMessage>Aadhar number is Mandatory and should be 12 Digit.</errorMessage>
</ValidationRule>
